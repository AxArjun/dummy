# FuelIQ — Environment Template
# Copy to .env and fill in values. NEVER commit .env to version control.

# ─── Application ──────────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=false
SECRET_KEY=change-me-to-a-secure-random-string-min-32-chars
TRUSTED_HOSTS=localhost,127.0.0.1,yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=fueliq
POSTGRES_USER=fueliq
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_URL=postgresql+asyncpg://fueliq:CHANGE_ME@localhost:5432/fueliq
DATABASE_READ_URL=  # Optional: set for read replica
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@localhost:6379/0
CELERY_BROKER_URL=redis://:CHANGE_ME_REDIS_PASSWORD@localhost:6379/1
CELERY_RESULT_BACKEND=redis://:CHANGE_ME_REDIS_PASSWORD@localhost:6379/2

# ─── Clerk Authentication ─────────────────────────────────────────────────────
CLERK_PUBLISHABLE_KEY=pk_test_cmVndWxhci1hbmNob3Z5LTYyLmNsZXJrLmFjY291bnRzLmRldiQ
CLERK_SECRET_KEY=sk_test_6AWq5rlHJanqDLhm0pYjOBspYvx7Uyw8qxWukpD6Sq
CLERK_JWKS_URL=https://your-clerk-domain.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER=https://your-clerk-domain.clerk.accounts.dev

# ─── MinIO / S3 ───────────────────────────────────────────────────────────────
S3_ENDPOINT_URL=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=CHANGE_ME_MINIO_SECRET
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=CHANGE_ME_MINIO_SECRET
S3_BUCKET_NAME=fueliq
MINIO_BUCKET=fueliq

# ─── Firebase ─────────────────────────────────────────────────────────────────
FIREBASE_SERVICE_ACCOUNT_JSON={"type": "service_account", "project_id": "..."}

# ─── Sentry (Optional) ────────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=120
RATE_LIMIT_AUTH_PER_MINUTE=10
RATE_LIMIT_OCR_PER_MINUTE=20
